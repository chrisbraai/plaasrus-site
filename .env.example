# ─── Environment variables — example ──────────────────────────────────────────
# Copy this file to .env.production (never commit that) and fill in real values.
# Push to Cloudflare Pages with: bash Yielde-System/tools/deploy/env-push.sh --slug <slug>

# ─── Core site config (required) ──────────────────────────────────────────────

# Canonical origin used by sitemap.ts, robots.ts, and JSON-LD emitters.
# Must match the production custom domain (not the *.pages.dev subdomain).
NEXT_PUBLIC_SITE_URL=https://example.com

# Set to true to enable the palette editor badge and /palette route.
# Keep this false in production builds — the editor is a development affordance only.
NEXT_PUBLIC_DEMO_MODE=false

# ─── Contact form (required if /contact is enabled) ───────────────────────────

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# The "From" address on outbound contact emails. Must be on a verified Resend domain.
FROM_EMAIL=contact@example.com

# The inbox that receives contact form submissions.
TO_EMAIL=chris@yielde.dev

# ─── Sanity CMS (required if the project adopts Sanity) ───────────────────────
# See knowledge/cms-path.md for when and why to enable.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_REVALIDATE_SECRET=

# ─── T2.16 — Upstash rate limiting (optional; production-grade replacement) ────
# The scaffold ships an in-memory rate limiter in src/app/api/contact/route.ts.
# In-memory works for single-instance Cloudflare Pages function windows but does
# not share state across cold starts or regions. Swap for Upstash when traffic
# volume warrants it:
#   npm install @upstash/ratelimit @upstash/redis
# Then uncomment the block in route.ts labelled "Upstash upgrade path" and set:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── T2.17 — Content-Security-Policy (optional; per-project) ──────────────────
# See src/middleware.ts for the CSP stub. The specific directives depend on which
# third-party origins the project uses (fonts, analytics, CMS, embedded maps).
# Enable with:
#   ENABLE_CSP=true
# Review with the report-only flag first:
#   CSP_REPORT_ONLY=true
ENABLE_CSP=false
CSP_REPORT_ONLY=false

# ─── T3.9 — Analytics + web-vitals (optional) ─────────────────────────────────
# Master switch for all analytics. When false, @vercel/analytics, Speed Insights,
# and the web-vitals reporter are tree-shaken out of the client bundle.
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Optional — web-vitals metrics are POSTed as JSON to this URL via sendBeacon
# when set. Leave empty to use dev-console logging only. Compatible with:
#   - Vercel Speed Insights (leave empty; @vercel/speed-insights handles it)
#   - Plausible Web Vitals goal (set to https://plausible.io/api/event)
#   - A custom route /api/vitals in this project
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=

# ─── T3.10 — Sentry error reporting (optional) ────────────────────────────────
# Provide the DSN from your Sentry project (https://sentry.io). When set,
# scaffold/instrumentation.ts initialises the SDK on server + edge runtimes
# and scaffold/instrumentation-client.ts initialises the browser SDK.
# Leave empty to disable — instrumentation becomes a no-op.
NEXT_PUBLIC_SENTRY_DSN=

# Sample rate for non-error transactions (0.0–1.0). 0.1 is a sensible default.
SENTRY_TRACES_SAMPLE_RATE=0.1
